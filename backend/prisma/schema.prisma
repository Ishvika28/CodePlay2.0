generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MatchHistory {

  id               Int      @id @default(autoincrement())

  roomCode         String

  roomName         String

  winnerName       String

  participantCount Int

  rankings         Json

  participants     Json?

  createdAt        DateTime @default(now())
}